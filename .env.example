# Supabase (public, safe in client + Netlify dashboard)
VITE_SUPABASE_URL=https://your-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Database connection (drizzle-kit migrations, .env.local only, NEVER in Netlify/production)
DATABASE_URL=postgresql://postgres:password@db.your-ref.supabase.co:5432/postgres

# Google OAuth secrets: DO NOT put in .env. Add Client ID + Secret to Supabase dashboard only.
# Supabase handles OAuth server-side; client app never sees secrets.
